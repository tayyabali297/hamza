{
  "name": "hamza",
  "version": "1.0.0",
  "description": "Hamza — Personal AI Life Assistant",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/copy-wasm.js",
    "dev": "concurrently \"vite\" \"wait-on tcp:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build",
    "package": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.hamza.personal",
    "productName": "Hamza",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "portable"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "vite": "^5.4.1",
    "wait-on": "^8.0.1"
  }
}
